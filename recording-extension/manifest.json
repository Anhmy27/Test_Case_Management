{
  "manifest_version": 3,
  "name": "TCM Smart Recording",
  "version": "0.1.0",
  "description": "Record browser actions as draft automation steps for Test Case Management.",
  "permissions": ["storage", "cookies"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TCM Smart Recording"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle",
      "type": "module",
      "all_frames": false
    }
  ]
}
