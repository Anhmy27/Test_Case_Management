# Bật production mode: ẩn stack trace + rút gọn lỗi upstream trong API response.
# Khi code local, comment dòng này (thêm # phía trước) để xem stack/chi tiết lỗi đầy đủ.
#NODE_ENV=production

MONGO_URI=mongodb://localhost:27017/Test_Case_Management
#MONGO_URI=mongodb://admin:admin123@localhost:27018/Test_Case_Management?authSource=admin
PORT=5000
JWT_SECRET=anhmy270903
# Default access-token lifetime is 8h when unset. Use shorter values in production.
JWT_EXPIRES_IN=8h
# Comma-separated if you also open FE via LAN IP, e.g. http://localhost:3000,http://192.168.110.57:3000
CORS_ORIGIN=http://localhost:3000

# Jira integration
JIRA_USERNAME=Anhmy
JIRA_PASSWORD=Adieu2709
# Optional: override the secret used to encrypt Jira credentials/session state in DB.
#JIRA_VAULT_SECRET=change-me
JIRA_BASE_URL=https://rd.cytech.ai

# Optional: seed one admin account on startup
ADMIN_NAME=Admin Root
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=12345678

# Automation security + artifacts
# Optional host allowlist for automation baseUrl/navigation (comma-separated, supports *.domain.com)
# AUTOMATION_ALLOWED_HOSTS=localhost,127.0.0.1,rd.cytech.ai,*.cytech.ai
# ARTIFACT_ROOT_DIR=uploads/runs
# AUTOMATION_UPLOAD_DIR=uploads/test-files
